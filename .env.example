# =========================================================================
# SmaartSchedule - Environment Configuration Template
# =========================================================================
# Instructions:
# 1. Copy this file to '.env' or '.env.local' in the root directory:
#    cp .env.example .env.local
# 2. Fill in the values for your environment (Supabase, Google Auth, etc.)
# 3. Do NOT commit your actual '.env' or '.env.local' files to version control.
# =========================================================================

# -------------------------------------------------------------------------
# Application Configuration
# -------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# -------------------------------------------------------------------------
# Security & Session Authentication
# -------------------------------------------------------------------------
# JWT Secret is used as a fallback for internal services or legacy tokens.
# A safe default is automatically generated in development mode.
JWT_SECRET=
JWT_EXPIRES_IN=1d
ADMIN_USER_IDS=1

# -------------------------------------------------------------------------
# Supabase Configuration (Authentication & Database)
# -------------------------------------------------------------------------
# Supabase URL & Anon Key (Required for Frontend Auth & Google Login)
# Dapatkan dari Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key

# Database Connection URI (Required for Backend direct DB access)
# Jika menggunakan Supabase CLI Lokal:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DB_HOST=127.0.0.1
DB_PORT=54322
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SSL=false

# -------------------------------------------------------------------------
# Google OAuth Configuration (Google Calendar)
# -------------------------------------------------------------------------
# NOTE: Autentikasi Login Google sekarang dikonfigurasi melalui Dashboard Supabase.
# Variabel di bawah ini digunakan HANYA untuk sinkronisasi Google Calendar.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/google/callback

# -------------------------------------------------------------------------
# Telegram Bot Integration Configuration
# -------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_BOT_USERNAME=
TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_WEBHOOK_ENABLED=false
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_REQUEST_TIMEOUT_MS=5000
TELEGRAM_MAX_RETRIES=2

# -------------------------------------------------------------------------
# Background Job Scheduler Configuration
# -------------------------------------------------------------------------
REMINDER_JOB_ENABLED=false
CRON_SECRET=
